{
  "name": "feed-mind",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "pnpm --filter @feed-mind/db generate",
    "db:migrate": "pnpm --filter @feed-mind/db migrate",
    "db:studio": "pnpm --filter @feed-mind/db studio",
    "dev:web": "pnpm --filter @feed-mind/web dev",
    "dev:api": "pnpm --filter @feed-mind/api dev",
    "dev:desktop": "pnpm --filter @feed-mind/desktop dev",
    "dev:mobile": "pnpm --filter @feed-mind/mobile dev",
    "dev:extension": "pnpm --filter @feed-mind/extension dev"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "turbo": "^2.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}